# ============ 必填 ============
# RedFox API Key（从 RedFox 平台获取）
REDFOX_API_KEY=your_redfox_api_key

# ============ LLM（选题生成、热点分析）============
# 任意 OpenAI Chat Completions 兼容服务
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# ============ 安全 ============
# 知识库凭证加密密钥（AES-256-GCM）
# 生成命令：openssl rand -hex 32
# 配置后请勿修改，否则已加密的数据无法解密
KB_ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_32_BYTES_HEX

# ============ 服务 ============
HOST=0.0.0.0
PORT=8080
# RedFox API 主机，默认 redfox.hk
REDFOX_HOST=redfox.hk
# 启用数据库中的 CRON 任务
ENABLE_SCHEDULER=true
# 时区，影响 data_date 边界、cron 触发、Date 字段解读
# 默认 Asia/Shanghai（中文自媒体场景）；海外用户改成对应 IANA 名，如 America/New_York
# USER_TIMEZONE=Asia/Shanghai

# ============ 本地 Agent（默认从 PATH 查找）============
CODEX_BIN=codex
CLAUDE_BIN=claude
KIMI_BIN=kimi
# Agent adapter 选择：
#   - 默认本地 spawn（npm start / npm run dev）
#   - Docker 部署下（/.dockerenv 存在 或 INSPRIRA_DEPLOYMENT=docker）自动切到 sbx
#     sbx CLI 需另装（https://docs.docker.com/ai/sandboxes/get-started/）
#   - AGENT_ADAPTER=local|sbx 强制 override，比如 Docker 内但仍想本地 spawn
# AGENT_ADAPTER=local
# INSPRIRA_DEPLOYMENT=docker
OPENCLAW_BIN=openclaw
HERMES_BIN=hermes

# ============ 可选 ============
# 查询 RedFox 官网账号剩余点数；填写浏览器登录后的完整 Cookie
REDFOX_WEB_COOKIE=
# Skill 中心社区更新走 GitHub API。未配置时匿名请求频率 60/hr 容易被 403 限流；
# 配置后提升到 5000/hr。Personal access token 即可，无需勾选任何权限（纯公开仓库读取）。
# 创建：https://github.com/settings/tokens → Generate new token → No scope
# GITHUB_API_TOKEN=ghp_xxx
# SQLite 文件路径，默认使用项目目录下的 cache.db
# CACHE_DB_PATH=/var/lib/insprira/cache.db
# 重启命令（默认检测 systemd；非 systemd 环境可指定，如 "pm2 restart insprira"）
# FURNACE_RESTART_CMD=

# 首次启动会在 SQLite 中创建默认账号 admin / 123456，登录后请立即修改密码
