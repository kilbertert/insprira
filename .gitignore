# 依赖
node_modules/

# 环境变量（含密钥，绝不能提交）
.env
.env.local
.env.*.local

# SQLite 数据库与 WAL
cache.db
cache.db-shm
cache.db-wal
*.sqlite
*.sqlite3

# 日志与运行时
*.log
server.log
nohup.out
app.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker / 本地数据挂载目录
data/

# Skill 目录（从官方仓库拉取/热更新，非本仓库源码）
skills/

# 备份压缩包
*.zip

# 本机 Claude Code 配置（含本地权限）
.claude/settings.local.json

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.bak

# Python（none 在本项目用，留作占位）
__pycache__/
*.pyc
*.pyo

# 构建产物
dist/
build/
*.min.js
*.min.css.map
# vendor/ 是本地化的第三方库，需要 commit
!vendor/*.min.js
